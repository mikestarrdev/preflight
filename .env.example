# Copy to .env.local and fill in. Never commit real values.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Direct Postgres connection for pnpm db:push (Supabase Session pooler URI, port 5432)
DATABASE_URL=

# Optional debug flags:
#   DEBUG_AGENT=1   structured step logs from the orchestrator
#   DEBUG_TOKENS=1  per-call token usage
#   NO_CACHE=1      bypass the .cache/ file cache
