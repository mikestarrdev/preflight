# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# scraped policy content stays out of the repo; rebuild with scripts/scrape-policies.ts
/data/raw/
/data/parsed/

# local tooling
.claude/

# model call cache (lib/cache.ts); rebuilt on demand
.cache/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
